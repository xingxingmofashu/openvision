{
  "name": "openvision",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run --cwd packages/chrome-extension --conditions=browser index.html"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.9",
      "@types/node": "25.3.1",
      "@tsconfig/bun": "1.0.10",
      "typescript": "5.9.3"
    }
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}